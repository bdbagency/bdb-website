<!-- Category filter logic -->
<script>
(function () {
  var btns = document.querySelectorAll('.cat-btn');
  var featured = document.querySelector('[data-categoria]');
  var allCards = document.querySelectorAll('[data-categoria]');

  btns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      // Update active state
      btns.forEach(function (b) {
        b.classList.remove('active', 'bg-dark', 'text-white', 'border-dark');
        b.classList.add('text-dark/60', 'border-dark/15');
      });
      btn.classList.add('active', 'bg-dark', 'text-white', 'border-dark');
      btn.classList.remove('text-dark/60', 'border-dark/15');

      var cat = btn.dataset.cat;

      allCards.forEach(function (card) {
        var match = cat === 'all' || card.dataset.categoria === cat;
        card.style.opacity = match ? '1' : '0.2';
        card.style.transform = match ? '' : 'scale(0.97)';
        card.style.pointerEvents = match ? '' : 'none';
        card.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
      });
    });
  });
})();
</script>

