  <a href="nosotros.html"   class="text-xl text-dark font-almarai font-bold">Nosotros</a>
  <a href="blog.html"       class="text-xl text-dark font-almarai font-bold">Blog</a>
  <a href="contacto.html"   class="text-xl text-dark font-almarai font-bold">Cont&aacute;ctanos</a>
  <a href="contacto.html" class="mt-4 bg-dark text-white text-center px-6 py-3 rounded-full text-base font-figtree font-semibold">Cotiza tu proyecto</a>
</div>

<!-- HERO -->
<section class="pt-32 pb-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="reveal text-center max-w-3xl mx-auto">
      <div class="flex justify-center mb-6">
        <div class="section-label">
          <span class="arrow-icon" style="-webkit-text-fill-color:initial;color:#0e1011;">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
          </span>
          Blog
        </div>
      </div>
      <h1 class="font-almarai font-bold leading-[1.05] tracking-tight mb-6" style="font-size: clamp(2.8rem, 7vw, 5.5rem);">Ideas y Tendencias</h1>
      <p class="text-dark/50 text-lg md:text-xl font-figtree leading-relaxed max-w-xl mx-auto">Estrategias, insights y tendencias del mundo digital para ayudarte a tomar mejores decisiones.</p>
    </div>
  </div>
</section>

<!-- BLOG GRID -->
<section class="py-12 pb-24">
  <div class="max-w-7xl mx-auto px-6">

    {% if collections.posts and collections.posts.length > 0 %}
    <!-- Real posts from CMS -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for post in collections.posts %}
      <a href="{{ post.url }}" class="reveal blog-card bg-light-g rounded-2xl overflow-hidden block group">
        <div class="overflow-hidden">
          {% if post.data.imagen %}
          <img src="{{ post.data.imagen }}" alt="{{ post.data.title }}"
               class="w-full h-52 object-cover" />
          {% else %}
          <div class="h-52 bg-gradient-to-br from-dark/10 via-dark/5 to-transparent flex items-center justify-center">
            <span class="font-serif text-6xl text-dark/10" style="font-family:'Instrument Serif',serif;">{{ loop.index | string | padStart(2, '0') }}</span>
          </div>
          {% endif %}
        </div>
        <div class="p-6">
          <div class="flex items-center justify-between mb-2">
            <span class="font-figtree text-xs text-dark/50 font-semibold uppercase tracking-wider">{{ post.data.categoria }}</span>
            <span class="font-figtree text-xs text-dark/35">{{ post.date | readableDate }}</span>
          </div>
          <h3 class="font-almarai font-bold text-dark text-xl mt-1 mb-2 group-hover:text-dark/80 transition-colors">{{ post.data.title }}</h3>
          <p class="text-dark/50 text-sm font-figtree leading-relaxed">{{ post.data.description }}</p>
          <div class="mt-4 flex items-center gap-2 text-sm font-figtree font-medium text-dark/60 group-hover:text-dark transition-colors">
            Leer art&iacute;culo
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </div>
        </div>
      </a>
      {% endfor %}
    </div>

    {% else %}
    <!-- Placeholder cards when no posts yet -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="reveal blog-card bg-light-g rounded-2xl overflow-hidden">
        <div class="h-52 bg-gradient-to-br from-dark/10 via-dark/5 to-transparent flex items-center justify-center relative">
          <span class="font-serif text-6xl text-dark/10">01</span>
          <div class="absolute top-4 right-4"><span class="bg-white/80 backdrop-blur-sm text-dark/60 font-figtree text-[10px] font-semibold px-3 py-1 rounded-full uppercase tracking-wider">Pr&oacute;ximamente</span></div>
        </div>
        <div class="p-6">
          <span class="font-figtree text-xs text-dark/50 font-semibold uppercase tracking-wider">Marketing Digital</span>
          <h3 class="font-almarai font-bold text-dark text-xl mt-2 mb-2">Tendencias de marketing digital en 2026</h3>
          <p class="text-dark/50 text-sm font-figtree leading-relaxed">Las estrategias que est&aacute;n definiendo el futuro del marketing este a&ntilde;o.</p>
        </div>
      </div>
      <div class="reveal blog-card bg-light-g rounded-2xl overflow-hidden">
        <div class="h-52 bg-gradient-to-br from-dark/[0.07] via-dark/[0.04] to-transparent flex items-center justify-center relative">
          <span class="font-serif text-6xl text-dark/10">02</span>
          <div class="absolute top-4 right-4"><span class="bg-white/80 backdrop-blur-sm text-dark/60 font-figtree text-[10px] font-semibold px-3 py-1 rounded-full uppercase tracking-wider">Pr&oacute;ximamente</span></div>
        </div>
        <div class="p-6">
          <span class="font-figtree text-xs text-dark/50 font-semibold uppercase tracking-wider">Branding</span>
          <h3 class="font-almarai font-bold text-dark text-xl mt-2 mb-2">C&oacute;mo construir una marca que conecta</h3>
          <p class="text-dark/50 text-sm font-figtree leading-relaxed">Los elementos clave para crear una identidad que resuene con tu audiencia.</p>
        </div>
      </div>
      <div class="reveal blog-card bg-light-g rounded-2xl overflow-hidden">
        <div class="h-52 bg-gradient-to-br from-dark/[0.08] via-dark/[0.03] to-transparent flex items-center justify-center relative">
          <span class="font-serif text-6xl text-dark/10">03</span>
          <div class="absolute top-4 right-4"><span class="bg-white/80 backdrop-blur-sm text-dark/60 font-figtree text-[10px] font-semibold px-3 py-1 rounded-full uppercase tracking-wider">Pr&oacute;ximamente</span></div>
        </div>
        <div class="p-6">
          <span class="font-figtree text-xs text-dark/50 font-semibold uppercase tracking-wider">Tecnolog&iacute;a e IA</span>
          <h3 class="font-almarai font-bold text-dark text-xl mt-2 mb-2">IA aplicada al marketing: casos reales</h3>
          <p class="text-dark/50 text-sm font-figtree leading-relaxed">C&oacute;mo la inteligencia artificial est&aacute; revolucionando la comunicaci&oacute;n de marcas.</p>
        </div>
      </div>
    </div>
    {% endif %}

  </div>
</section>

