---
permalink: blog.html
eleventyExcludeFromCollections: true
title: "Blog — BDB Agency"
description: "Blog de BDB Agency. Ideas, tendencias y estrategias de marketing digital, branding, tecnología e inteligencia artificial."
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <link rel="icon" href="img/favicon.png" />
  <link rel="canonical" href="{{ site.url }}/blog.html" />
  <meta property="og:title"       content="{{ title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:url"         content="{{ site.url }}/blog.html" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Almarai:wght@300;400;700;800&family=Figtree:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            dark:      '#0e1011',
            'dark-card': '#202527',
            'dark-bd': '#2c2e2f',
            cream:     '#fdfbf6',
            'light-g': '#f6f6f6',
            lime:      '#0FB4F7',
          },
          fontFamily: {
            almarai: ['Almarai', 'sans-serif'],
            figtree: ['Figtree', 'sans-serif'],
            serif:   ['Instrument Serif', 'Georgia', 'serif'],
            inter:   ['Inter', 'system-ui', 'sans-serif'],
          },
        }
      }
    }
  </script>

  <style>
    html { scroll-behavior: smooth; }
    body { font-family: 'Figtree', sans-serif; background: #ffffff; color: #0e1011; overflow-x: hidden; }
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s cubic-bezier(.25,.46,.45,.94), transform 0.7s cubic-bezier(.25,.46,.45,.94); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    #navbar { background: transparent; }
    .nav-part { background: rgba(255,255,255,0.95); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); transition: all 0.5s cubic-bezier(.4,0,.2,1); }
    .nav-center { border-radius: 0 0 20px 20px; }
    .nav-left  { border-radius: 24px 0 20px 0; background: transparent; backdrop-filter: none; -webkit-backdrop-filter: none; }
    .nav-right { border-radius: 0 24px 0 20px; background: transparent; backdrop-filter: none; -webkit-backdrop-filter: none; }
    .nav-left, .nav-right { opacity: 1; max-width: 200px; overflow: hidden; transition: opacity 0.4s cubic-bezier(.4,0,.2,1), max-width 0.4s cubic-bezier(.4,0,.2,1), padding 0.4s cubic-bezier(.4,0,.2,1); }
    #navbar.nav-hide-sides .nav-left, #navbar.nav-hide-sides .nav-right { opacity: 0; max-width: 0; padding-left: 0; padding-right: 0; pointer-events: none; }
    .nav-center { transition: none; }
    #navbar .nav-link { color: rgba(14,16,17,0.6); transition: color 0.3s ease; }
    #navbar .nav-link:hover { color: #0e1011; }
    #navbar .nav-logo { color: #0e1011; }
    #navbar .nav-cta-btn { background: #0e1011; color: #fff; border-radius: 500px; transition: all 0.3s ease; }
    #navbar .nav-cta-btn:hover { background: #2a2d2f; }
    #navbar .menu-bar { background: #0e1011; }
    .white-top-bar { position: fixed; top: 0; left: 0; right: 0; height: 12px; background: #fff; z-index: 40; }
    .white-top-bar::before, .white-top-bar::after { content: ''; position: absolute; bottom: -32px; width: 32px; height: 32px; }
    .white-top-bar::before { left: 12px; background: radial-gradient(circle at 100% 100%, transparent 32px, #fff 32px); }
    .white-top-bar::after  { right: 12px; background: radial-gradient(circle at 0 100%, transparent 32px, #fff 32px); }
    #mobile-menu { transform: translateX(100%); transition: transform 0.35s cubic-bezier(.77,0,.175,1); }
    #mobile-menu.open { transform: translateX(0); }
    .section-label { display: inline-flex; align-items: center; gap: 8px; font-family: 'Figtree', sans-serif; font-size: 13px; font-weight: 500; }
    .section-label { background: linear-gradient(90deg, #0e1011 0%, #0e1011 40%, #0FB4F7 55%, #0e1011 70%, #0e1011 100%); background-size: 300% 100%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: label-shine 4s ease infinite; }
    @keyframes label-shine { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
    .section-label .arrow-icon { width: 28px; height: 28px; border-radius: 50%; border: 1px solid rgba(14,16,17,0.15); display: flex; align-items: center; justify-content: center; }
    .btn-arrow { display: inline-flex; align-items: center; gap: 10px; padding: 12px 24px; border: 1px solid rgba(14,16,17,0.15); border-radius: 9999px; font-family: 'Figtree', sans-serif; font-weight: 500; font-size: 14px; color: #0e1011; transition: all 0.3s ease; }
    .btn-arrow:hover { background: #0e1011; color: #fff; border-color: #0e1011; }
    .btn-arrow-white { border-color: rgba(255,255,255,0.25); color: #fff; }
    .btn-arrow-white:hover { background: #fff; color: #0e1011; border-color: #fff; }

    /* ── BLOG CARDS ── */
    .blog-card-item { transition: transform 0.35s ease, box-shadow 0.35s ease; }
    .blog-card-item:hover { transform: translateY(-4px); box-shadow: 0 24px 56px rgba(0,0,0,0.09); }
    .blog-card-img { transition: transform 0.55s cubic-bezier(.25,.46,.45,.94); }
    .blog-card-item:hover .blog-card-img { transform: scale(1.04); }

    /* ── FEATURED CARD ── */
    .featured-card { transition: transform 0.35s ease, box-shadow 0.35s ease; }
    .featured-card:hover { transform: translateY(-3px); box-shadow: 0 28px 64px rgba(0,0,0,0.1); }
    .featured-card .feat-img { transition: transform 0.65s cubic-bezier(.25,.46,.45,.94); }
    .featured-card:hover .feat-img { transform: scale(1.03); }
    .feat-arrow { transition: background 0.3s ease, transform 0.3s ease; }
    .featured-card:hover .feat-arrow { background: #0e1011; }
    .featured-card:hover .feat-arrow svg { stroke: #fff; }

    /* ── CATEGORY FILTER ── */
    .cat-btn { transition: all 0.25s ease; }
    .cat-btn.active { background: #0e1011; color: #fff; border-color: #0e1011; }

    /* ── LINE CLAMP ── */
    .line-clamp-2 { overflow: hidden; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
    .line-clamp-3 { overflow: hidden; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3; }

    @media (pointer: fine) { *, *::before, *::after { cursor: none !important; } }
  </style>
</head>
<body>

<!-- NAV -->
<div class="white-top-bar"></div>
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50">
  <div class="px-3 md:px-4 pt-3 flex items-start justify-between gap-2">
    <div class="nav-part nav-left hidden md:flex items-center px-5 h-11 mt-4 ml-4">
      <a href="index.html" class="nav-logo font-almarai font-bold text-base tracking-tight whitespace-nowrap">BDB <sup class="text-[9px] font-normal">&reg;</sup></a>
    </div>
    <div class="nav-part nav-center flex items-center justify-center h-11 px-2">
      <div class="hidden md:flex items-center gap-1">
        <a href="portafolio.html" class="nav-link text-sm font-figtree font-medium px-4 py-2 rounded-full hover:bg-black/5 transition-colors">Portafolio</a>
        <a href="nosotros.html"   class="nav-link text-sm font-figtree font-medium px-4 py-2 rounded-full hover:bg-black/5 transition-colors">Nosotros</a>
        <a href="blog.html"       class="nav-link text-sm font-figtree font-medium px-4 py-2 rounded-full hover:bg-black/5 transition-colors" style="color:#0e1011;">Blog</a>
        <a href="contacto.html"   class="nav-link text-sm font-figtree font-medium px-4 py-2 rounded-full hover:bg-black/5 transition-colors">Cont&aacute;ctanos</a>
      </div>
      <div class="md:hidden flex items-center justify-between w-full px-3">
        <a href="index.html" class="nav-logo font-almarai font-bold text-base tracking-tight">BDB <sup class="text-[9px] font-normal">&reg;</sup></a>
        <button id="menu-toggle" class="p-2 flex flex-col gap-1.5" aria-label="Men&uacute;">
          <span class="menu-bar w-5 h-px block"></span>
          <span class="menu-bar w-5 h-px block"></span>
          <span class="menu-bar w-3 h-px block ml-auto"></span>
        </button>
      </div>
    </div>
    <div class="nav-part nav-right hidden md:flex items-center px-2 h-11 mt-4 mr-4">
      <a href="contacto.html" class="nav-cta-btn inline-flex items-center gap-2 px-5 py-2 text-sm font-figtree font-semibold">Cont&aacute;ctanos</a>
    </div>
  </div>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu" class="fixed top-0 right-0 h-screen w-72 bg-white z-[100] p-8 flex flex-col gap-6 border-l border-black/5 shadow-2xl">
  <button id="menu-close" class="self-end text-dark/40 hover:text-dark p-1">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
  <a href="portafolio.html" class="text-xl text-dark font-almarai font-bold">Portafolio</a>
  <a href="nosotros.html"   class="text-xl text-dark font-almarai font-bold">Nosotros</a>
  <a href="blog.html"       class="text-xl text-dark font-almarai font-bold">Blog</a>
  <a href="contacto.html"   class="text-xl text-dark font-almarai font-bold">Cont&aacute;ctanos</a>
  <a href="contacto.html" class="mt-4 bg-dark text-white text-center px-6 py-3 rounded-full text-base font-figtree font-semibold">Cotiza tu proyecto</a>
</div>

<!-- ════════════════════════════════════════
     HERO — Editorial left-aligned
════════════════════════════════════════ -->
<section class="pt-36 pb-16 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="relative">

      <!-- Ghost decorative text (21st Magic "Blog Posts" pattern) -->
      <span class="absolute -top-8 -left-2 select-none font-almarai font-extrabold leading-none text-dark pointer-events-none z-0 whitespace-nowrap hidden md:block"
            style="font-size:clamp(5rem,18vw,13rem); opacity:0.028;">BLOG</span>

      <div class="relative z-10">
        <!-- Section label -->
        <div class="flex items-center gap-3 mb-8 reveal">
          <div class="section-label">
            <span class="arrow-icon" style="-webkit-text-fill-color:initial;color:#0e1011;">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
            </span>
            Ideas y Tendencias
          </div>
        </div>

        <!-- Two-column hero: title left, description right -->
        <div class="grid md:grid-cols-2 gap-8 md:gap-16 items-end">
          <div class="reveal">
            <h1 class="font-almarai font-bold leading-[1.0] tracking-tight"
                style="font-size:clamp(3rem,8vw,6.5rem); letter-spacing:-0.025em;">
              Nuestra <br class="hidden md:block"><em class="font-serif italic font-normal" style="font-family:'Instrument Serif',Georgia,serif;">perspectiva</em>
            </h1>
          </div>
          <div class="md:pb-2 reveal" data-delay="100">
            <div class="w-8 h-px bg-dark/20 mb-6 hidden md:block"></div>
            <p class="text-dark/50 text-lg font-figtree leading-relaxed max-w-md">
              Estrategias, insights y tendencias del mundo digital para ayudarte a tomar mejores decisiones.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ════════════════════════════════════════
     CATEGORY FILTER
════════════════════════════════════════ -->
<div class="max-w-7xl mx-auto px-6 pb-10 reveal">
  <div class="flex flex-wrap gap-2" id="category-filter">
    <button class="cat-btn active font-figtree text-sm font-semibold px-5 py-2 rounded-full bg-dark text-white border border-dark" data-cat="all">
      Todos
    </button>
    <button class="cat-btn font-figtree text-sm font-medium px-5 py-2 rounded-full border border-dark/15 text-dark/60 hover:border-dark hover:text-dark" data-cat="Marketing Digital">
      Marketing Digital
    </button>
    <button class="cat-btn font-figtree text-sm font-medium px-5 py-2 rounded-full border border-dark/15 text-dark/60 hover:border-dark hover:text-dark" data-cat="Branding">
      Branding
    </button>
    <button class="cat-btn font-figtree text-sm font-medium px-5 py-2 rounded-full border border-dark/15 text-dark/60 hover:border-dark hover:text-dark" data-cat="Tecnología e IA">
      Tecnolog&iacute;a e IA
    </button>
  </div>
</div>

<!-- ════════════════════════════════════════
     BLOG GRID
════════════════════════════════════════ -->
<section class="pb-24">
  <div class="max-w-7xl mx-auto px-6">

    {% if collections.posts and collections.posts.length > 0 %}

    <!-- ── FEATURED FIRST POST ── -->
    {% set featured = collections.posts[0] %}
    <div class="mb-8 reveal">
      <a href="{{ featured.url }}"
         class="featured-card blog-card-item group grid md:grid-cols-[1.2fr_1fr] bg-light-g rounded-2xl overflow-hidden block"
         data-categoria="{{ featured.data.categoria }}">

        <!-- Image: left, tall -->
        <div class="overflow-hidden relative" style="aspect-ratio:4/3; min-height:280px;">
          {% if featured.data.imagen %}
          <img src="{{ featured.data.imagen }}" alt="{{ featured.data.title }}"
               class="feat-img w-full h-full object-cover" />
          {% else %}
          <div class="w-full h-full bg-gradient-to-br from-dark/10 to-dark/5 flex items-center justify-center">
            <span class="font-serif text-9xl text-dark/[0.08]" style="font-family:'Instrument Serif',serif;">01</span>
          </div>
          {% endif %}
          <!-- Subtle gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent pointer-events-none"></div>
        </div>

        <!-- Content: right, vertically distributed -->
        <div class="flex flex-col justify-between p-8 md:p-10 lg:p-12">
          <div>
            <!-- Top row: category + date -->
            <div class="flex items-center justify-between mb-6">
              {% if featured.data.categoria %}
              <span class="inline-flex items-center bg-lime/10 text-lime border border-lime/20 font-figtree text-[11px] font-semibold px-3 py-1.5 rounded-full uppercase tracking-widest">
                {{ featured.data.categoria }}
              </span>
              {% endif %}
              <time class="font-figtree text-xs text-dark/35">{{ featured.date | readableDate }}</time>
            </div>

            <!-- Title -->
            <h2 class="font-almarai font-bold text-dark leading-[1.08] mb-4 group-hover:text-dark/80 transition-colors"
                style="font-size:clamp(1.5rem,3vw,2.2rem); letter-spacing:-0.02em;">
              {{ featured.data.title }}
            </h2>

            <!-- Description -->
            <p class="text-dark/55 font-figtree leading-relaxed text-base line-clamp-3">
              {{ featured.data.description }}
            </p>
          </div>

          <!-- CTA row -->
          <div class="mt-8 flex items-center gap-3 pt-6 border-t border-dark/[0.06]">
            <span class="font-figtree text-sm font-semibold text-dark group-hover:text-lime transition-colors">
              Leer art&iacute;culo
            </span>
            <div class="feat-arrow w-8 h-8 rounded-full border border-dark/15 flex items-center justify-center ml-auto">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
              </svg>
            </div>
          </div>
        </div>

      </a>
    </div>

    <!-- ── SECONDARY POSTS GRID ── -->
    {% if collections.posts.length > 1 %}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {% for post in collections.posts %}
      {% if loop.index > 1 %}
      <a href="{{ post.url }}"
         class="blog-card-item spotlight-card group flex flex-col bg-light-g rounded-2xl overflow-hidden reveal"
         data-categoria="{{ post.data.categoria }}"
         data-delay="{{ (loop.index - 2) * 80 }}">

        <!-- Image with overlay badge -->
        <div class="overflow-hidden relative" style="aspect-ratio:16/10;">
          {% if post.data.imagen %}
          <img src="{{ post.data.imagen }}" alt="{{ post.data.title }}"
               class="blog-card-img w-full h-full object-cover" />
          {% else %}
          <div class="w-full h-full bg-gradient-to-br from-dark/[0.09] via-dark/[0.05] to-transparent flex items-center justify-center">
            <span class="font-serif text-7xl text-dark/[0.08]" style="font-family:'Instrument Serif',serif;">
              {{ loop.index | string | padStart(2, '0') }}
            </span>
          </div>
          {% endif %}

          <!-- Gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/25 via-transparent to-transparent pointer-events-none"></div>

          <!-- Category badge overlaid on image (21st Magic "Blogs" pattern) -->
          {% if post.data.categoria %}
          <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-dark/70 font-figtree text-[10px] font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full">
            {{ post.data.categoria }}
          </span>
          {% endif %}
        </div>

        <!-- Card body -->
        <div class="p-5 flex flex-col flex-1">
          <time class="font-figtree text-xs text-dark/35 mb-3 block">{{ post.date | readableDate }}</time>
          <h3 class="font-almarai font-bold text-dark leading-snug mb-2 flex-1 group-hover:text-dark/75 transition-colors"
              style="font-size:1.05rem; letter-spacing:-0.01em;">
            {{ post.data.title }}
          </h3>
          <p class="text-dark/50 text-sm font-figtree leading-relaxed line-clamp-2 mb-4">{{ post.data.description }}</p>

          <!-- Footer row -->
          <div class="flex items-center gap-2 text-sm font-figtree font-medium text-dark/45 group-hover:text-dark transition-colors mt-auto pt-4 border-t border-dark/[0.05]">
            Leer art&iacute;culo
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        </div>

      </a>
      {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% else %}

    <!-- ── PLACEHOLDER CARDS (when no posts) ── -->
    <div class="mb-8 reveal">
      <div class="featured-card grid md:grid-cols-[1.2fr_1fr] bg-light-g rounded-2xl overflow-hidden">
        <div class="relative overflow-hidden" style="aspect-ratio:4/3; min-height:280px;">
          <div class="w-full h-full bg-gradient-to-br from-dark/10 to-dark/5 flex items-center justify-center">
            <span class="font-serif text-9xl text-dark/[0.08]" style="font-family:'Instrument Serif',serif;">01</span>
          </div>
          <div class="absolute top-3 right-3">
            <span class="bg-white/80 backdrop-blur-sm text-dark/60 font-figtree text-[10px] font-semibold px-3 py-1.5 rounded-full uppercase tracking-widest">Pr&oacute;ximamente</span>
          </div>
        </div>
        <div class="flex flex-col justify-between p-8 md:p-12">
          <div>
            <span class="inline-flex items-center bg-lime/10 text-lime border border-lime/20 font-figtree text-[11px] font-semibold px-3 py-1.5 rounded-full uppercase tracking-widest mb-6 block w-fit">Marketing Digital</span>
            <h2 class="font-almarai font-bold text-dark text-2xl md:text-3xl leading-tight mb-4">Tendencias de marketing digital en 2026</h2>
            <p class="text-dark/55 font-figtree leading-relaxed">Las estrategias que est&aacute;n definiendo el futuro del marketing este a&ntilde;o.</p>
          </div>
          <div class="mt-8 flex items-center gap-3 pt-6 border-t border-dark/[0.06]">
            <span class="font-figtree text-sm font-semibold text-dark">Leer art&iacute;culo</span>
            <div class="w-8 h-8 rounded-full border border-dark/15 flex items-center justify-center ml-auto">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      <div class="reveal blog-card-item flex flex-col bg-light-g rounded-2xl overflow-hidden">
        <div class="relative overflow-hidden" style="aspect-ratio:16/10;">
          <div class="w-full h-full bg-gradient-to-br from-dark/[0.08] via-dark/[0.04] to-transparent flex items-center justify-center">
            <span class="font-serif text-7xl text-dark/[0.08]" style="font-family:'Instrument Serif',serif;">02</span>
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent"></div>
          <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-dark/70 font-figtree text-[10px] font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full">Branding</span>
          <span class="absolute top-3 right-3 bg-white/80 backdrop-blur-sm text-dark/60 font-figtree text-[10px] font-semibold px-3 py-1 rounded-full">Pr&oacute;ximamente</span>
        </div>
        <div class="p-5 flex flex-col flex-1">
          <h3 class="font-almarai font-bold text-dark text-[1.05rem] leading-snug mb-2 flex-1">C&oacute;mo construir una marca que conecta</h3>
          <p class="text-dark/50 text-sm font-figtree leading-relaxed line-clamp-2 mb-4">Los elementos clave para crear una identidad que resuene con tu audiencia.</p>
          <div class="flex items-center gap-2 text-sm font-figtree font-medium text-dark/40 mt-auto pt-4 border-t border-dark/[0.05]">Leer art&iacute;culo <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></div>
        </div>
      </div>
