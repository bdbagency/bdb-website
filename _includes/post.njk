<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  {# SEO #}
  <title>{{ title }} | BDB Agency</title>
  <meta name="description" content="{{ description }}" />
  <link rel="icon" href="/img/favicon.png" />
  <link rel="canonical" href="{{ site.url }}/blog/{{ page.fileSlug }}/" />

  {# Open Graph #}
  <meta property="og:type"        content="article" />
  <meta property="og:title"       content="{{ title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:url"         content="{{ site.url }}/blog/{{ page.fileSlug }}/" />
  <meta property="og:image"       content="{{ site.url }}{{ imagen if imagen else site.ogImage }}" />
  <meta property="article:published_time" content="{{ date | isoDate }}" />

  {# Twitter Card #}
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="{{ title }}" />
  <meta name="twitter:description" content="{{ description }}" />
  <meta name="twitter:image"       content="{{ site.url }}{{ imagen if imagen else site.ogImage }}" />

  {# JSON-LD Structured Data #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title | replace('"', '\\"') }}",
    "description": "{{ description | replace('"', '\\"') }}",
    "datePublished": "{{ date | isoDate }}",
    "image": "{{ site.url }}{{ imagen if imagen else site.ogImage }}",
    "url": "{{ site.url }}/blog/{{ page.fileSlug }}/",
    "author": {
      "@type": "Organization",
      "name": "BDB Agency",
      "url": "{{ site.url }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "BDB Agency",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ site.url }}/img/logo.png"
      }
    }
  }
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Almarai:wght@300;400;700;800&family=Figtree:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            dark:        '#0e1011',
            'dark-card': '#202527',
            'dark-bd':   '#2c2e2f',
            cream:       '#fdfbf6',
            'light-g':   '#f6f6f6',
            lime:        '#0FB4F7',
          },
          fontFamily: {
            almarai: ['Almarai', 'sans-serif'],
            figtree: ['Figtree', 'sans-serif'],
            serif:   ['Instrument Serif', 'Georgia', 'serif'],
            inter:   ['Inter', 'system-ui', 'sans-serif'],
          },
        }
      }
    }
  </script>

  <style>
    html { scroll-behavior: smooth; }
    body { font-family: 'Figtree', sans-serif; background: #ffffff; color: #0e1011; overflow-x: hidden; }

    /* ── SCROLL REVEAL ── */
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s cubic-bezier(.25,.46,.45,.94), transform 0.7s cubic-bezier(.25,.46,.45,.94); }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── NAV ── */
    #navbar { background: transparent; }
    .nav-part { background: rgba(255,255,255,0.95); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); transition: all 0.5s cubic-bezier(.4,0,.2,1); }
    .nav-center { border-radius: 0 0 20px 20px; }
    .nav-left  { border-radius: 24px 0 20px 0; background: transparent; backdrop-filter: none; -webkit-backdrop-filter: none; }
    .nav-right { border-radius: 0 24px 0 20px; background: transparent; backdrop-filter: none; -webkit-backdrop-filter: none; }
    .nav-left, .nav-right { opacity: 1; max-width: 200px; overflow: hidden; transition: opacity 0.4s cubic-bezier(.4,0,.2,1), max-width 0.4s cubic-bezier(.4,0,.2,1), padding 0.4s cubic-bezier(.4,0,.2,1); }
    #navbar.nav-hide-sides .nav-left, #navbar.nav-hide-sides .nav-right { opacity: 0; max-width: 0; padding-left: 0; padding-right: 0; pointer-events: none; }
    .nav-center { transition: none; }
    #navbar .nav-link { color: rgba(14,16,17,0.6); transition: color 0.3s ease; }
    #navbar .nav-link:hover { color: #0e1011; }
    #navbar .nav-logo { color: #0e1011; }
    #navbar .nav-cta-btn { background: #0e1011; color: #fff; border-radius: 500px; transition: all 0.3s ease; }
    #navbar .nav-cta-btn:hover { background: #2a2d2f; }
    #navbar .menu-bar { background: #0e1011; }

    /* ── WHITE TOP BAR ── */
    .white-top-bar { position: fixed; top: 0; left: 0; right: 0; height: 12px; background: #fff; z-index: 40; }
    .white-top-bar::before, .white-top-bar::after { content: ''; position: absolute; bottom: -32px; width: 32px; height: 32px; }
    .white-top-bar::before { left: 12px; background: radial-gradient(circle at 100% 100%, transparent 32px, #fff 32px); }
    .white-top-bar::after  { right: 12px; background: radial-gradient(circle at 0 100%, transparent 32px, #fff 32px); }

    /* ── MOBILE MENU ── */
    #mobile-menu { transform: translateX(100%); transition: transform 0.35s cubic-bezier(.77,0,.175,1); }
    #mobile-menu.open { transform: translateX(0); }

    /* ── SECTION LABEL ── */
    .section-label { display: inline-flex; align-items: center; gap: 8px; font-family: 'Figtree', sans-serif; font-size: 13px; font-weight: 500; }
    .section-label { background: linear-gradient(90deg, #0e1011 0%, #0e1011 40%, #0FB4F7 55%, #0e1011 70%, #0e1011 100%); background-size: 300% 100%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: label-shine 4s ease infinite; }
    @keyframes label-shine { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
    .section-label .arrow-icon { width: 28px; height: 28px; border-radius: 50%; border: 1px solid rgba(14,16,17,0.15); display: flex; align-items: center; justify-content: center; -webkit-text-fill-color: initial; color: #0e1011; }

    /* ── BUTTONS ── */
    .btn-arrow { display: inline-flex; align-items: center; gap: 10px; padding: 12px 24px; border: 1px solid rgba(14,16,17,0.15); border-radius: 9999px; font-family: 'Figtree', sans-serif; font-weight: 500; font-size: 14px; color: #0e1011; transition: all 0.3s ease; }
    .btn-arrow:hover { background: #0e1011; color: #fff; border-color: #0e1011; }
    .btn-arrow-white { border-color: rgba(255,255,255,0.25); color: #fff; }
    .btn-arrow-white:hover { background: #fff; color: #0e1011; border-color: #fff; }

    /* ── ARTICLE PROSE ── */
    .prose h2 { font-family: 'Almarai', sans-serif; font-weight: 700; font-size: 1.625rem; line-height: 1.25; margin: 2.75rem 0 1rem; color: #0e1011; }
    .prose h3 { font-family: 'Almarai', sans-serif; font-weight: 700; font-size: 1.2rem; line-height: 1.35; margin: 2rem 0 0.75rem; color: #0e1011; }
    .prose p  { font-family: 'Figtree', sans-serif; font-size: 1.0625rem; line-height: 1.8; color: rgba(14,16,17,0.72); margin-bottom: 1.5rem; }
    .prose ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 1.5rem; }
    .prose ol { list-style: decimal; padding-left: 1.5rem; margin-bottom: 1.5rem; }
    .prose li { font-family: 'Figtree', sans-serif; font-size: 1.0625rem; line-height: 1.75; color: rgba(14,16,17,0.72); margin-bottom: 0.4rem; }
    .prose strong { color: #0e1011; font-weight: 600; }
    .prose a { color: #0FB4F7; text-decoration: underline; text-underline-offset: 2px; }
    .prose a:hover { color: #0a8fc4; }
    .prose blockquote { border-left: 3px solid #0FB4F7; padding: 0.5rem 0 0.5rem 1.5rem; margin: 2rem 0; font-style: italic; color: rgba(14,16,17,0.55); background: #f6f6f6; border-radius: 0 12px 12px 0; }
    .prose img { width: 100%; border-radius: 16px; margin: 2rem 0; }
    .prose hr { border: none; border-top: 1px solid rgba(14,16,17,0.08); margin: 3rem 0; }

    /* ── HIDE NATIVE CURSOR when custom cursor active ── */
    @media (pointer: fine) { *, *::before, *::after { cursor: none !important; } }
  </style>
</head>
<body>

<!-- NAV -->
<div class="white-top-bar"></div>
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50">
  <div class="px-3 md:px-4 pt-3 flex items-start justify-between gap-2">
    <div class="nav-part nav-left hidden md:flex items-center px-5 h-11 mt-4 ml-4">
      <a href="/index.html" class="nav-logo font-almarai font-bold text-base tracking-tight whitespace-nowrap">BDB <sup class="text-[9px] font-normal">&reg;</sup></a>
    </div>
    <div class="nav-part nav-center flex items-center justify-center h-11 px-2">
      <div class="hidden md:flex items-center gap-1">
        <a href="/portafolio.html" class="nav-link text-sm font-figtree font-medium px-4 py-2 rounded-full hover:bg-black/5 transition-colors">Portafolio</a>
        <a href="/nosotros.html"   class="nav-link text-sm font-figtree font-medium px-4 py-2 rounded-full hover:bg-black/5 transition-colors">Nosotros</a>
        <a href="/blog.html"       class="nav-link text-sm font-figtree font-medium px-4 py-2 rounded-full hover:bg-black/5 transition-colors" style="color:#0e1011;">Blog</a>
        <a href="/contacto.html"   class="nav-link text-sm font-figtree font-medium px-4 py-2 rounded-full hover:bg-black/5 transition-colors">Cont&aacute;ctanos</a>
      </div>
      <div class="md:hidden flex items-center justify-between w-full px-3">
        <a href="/index.html" class="nav-logo font-almarai font-bold text-base tracking-tight">BDB <sup class="text-[9px] font-normal">&reg;</sup></a>
        <button id="menu-toggle" class="p-2 flex flex-col gap-1.5" aria-label="Men&uacute;">
          <span class="menu-bar w-5 h-px block"></span>
          <span class="menu-bar w-5 h-px block"></span>
          <span class="menu-bar w-3 h-px block ml-auto"></span>
        </button>
      </div>
    </div>
    <div class="nav-part nav-right hidden md:flex items-center px-2 h-11 mt-4 mr-4">
      <a href="/contacto.html" class="nav-cta-btn inline-flex items-center gap-2 px-5 py-2 text-sm font-figtree font-semibold">Cont&aacute;ctanos</a>
    </div>
  </div>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu" class="fixed top-0 right-0 h-screen w-72 bg-white z-[100] p-8 flex flex-col gap-6 border-l border-black/5 shadow-2xl">
  <button id="menu-close" class="self-end text-dark/40 hover:text-dark p-1">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
  <a href="/portafolio.html" class="text-xl text-dark font-almarai font-bold">Portafolio</a>
  <a href="/nosotros.html"   class="text-xl text-dark font-almarai font-bold">Nosotros</a>
  <a href="/blog.html"       class="text-xl text-dark font-almarai font-bold">Blog</a>
  <a href="/contacto.html"   class="text-xl text-dark font-almarai font-bold">Cont&aacute;ctanos</a>
  <a href="/contacto.html" class="mt-4 bg-dark text-white text-center px-6 py-3 rounded-full text-base font-figtree font-semibold">Cotiza tu proyecto</a>
</div>

<!-- ═══ ARTICLE HEADER ═══ -->
<article>
  <header class="pt-32 pb-12 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <!-- Breadcrumb + category -->
      <div class="flex items-center gap-3 mb-8 reveal">
        <a href="/blog.html" class="section-label">
          <span class="arrow-icon">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="-webkit-text-fill-color:initial;color:#0e1011;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          </span>
          Blog
        </a>
        {% if categoria %}
        <span class="text-dark/25">·</span>
        <span class="bg-dark/5 text-dark/60 font-figtree text-xs font-semibold px-3 py-1 rounded-full">{{ categoria }}</span>
        {% endif %}
      </div>

      <!-- Title -->
      <h1 class="font-almarai font-bold leading-[1.05] tracking-tight mb-6 reveal" style="font-size: clamp(2rem, 5vw, 3.5rem);">{{ title }}</h1>

      <!-- Meta row -->
      <div class="flex items-center gap-6 text-sm text-dark/40 font-figtree mb-8 reveal">
        <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
        <span>BDB Agency</span>
      </div>

      <!-- Description -->
      {% if description %}
      <p class="text-dark/55 text-lg font-figtree leading-relaxed border-l-4 pl-5 mb-0 reveal" style="border-color:#0FB4F7;">{{ description }}</p>
      {% endif %}
    </div>
  </header>

  <!-- Cover image -->
  {% if imagen %}
  <div class="max-w-5xl mx-auto px-6 mb-12 reveal">
    <img src="{{ imagen }}" alt="{{ title }}" class="w-full rounded-3xl object-cover" style="max-height:520px;" />
  </div>
  {% endif %}

  <!-- ═══ POST CONTENT ═══ -->
  <div class="max-w-3xl mx-auto px-6 pb-20">
    <div class="prose">
      {{ content | safe }}
    </div>

    <!-- Back + CTA -->
    <div class="mt-16 pt-10 border-t border-black/8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <a href="/blog.html" class="btn-arrow text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Volver al blog
      </a>
      <a href="/contacto.html" class="bg-dark text-white font-figtree font-semibold px-7 py-3 rounded-full text-sm hover:bg-dark/80 transition-colors">
        &iquest;Necesitas ayuda con tu marketing? &rarr;
      </a>
    </div>
  </div>
</article>

<!-- ═══ FOOTER ═══ -->
<footer class="bg-white px-3 md:px-4 pb-3">
  <div class="bg-dark rounded-3xl overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-4 gap-12">
        <div class="md:col-span-1">
          <p class="font-almarai font-bold text-white text-xl mb-4">BDB <sup class="text-[8px] font-normal">&reg;</sup></p>
          <p class="text-white/40 text-sm font-figtree leading-relaxed">Agencia de marketing digital en Canc&uacute;n. Branding, producci&oacute;n audiovisual, marketing y desarrollo web.</p>
        </div>
        <div>
          <h4 class="text-white/30 text-xs uppercase tracking-widest font-figtree font-semibold mb-4">Navegaci&oacute;n</h4>
          <ul class="space-y-3">
            <li><a href="/portafolio.html" class="text-white/60 hover:text-white text-sm font-figtree transition-colors">Portafolio</a></li>
            <li><a href="/nosotros.html"   class="text-white/60 hover:text-white text-sm font-figtree transition-colors">Nosotros</a></li>
            <li><a href="/blog.html"       class="text-white/60 hover:text-white text-sm font-figtree transition-colors">Blog</a></li>
            <li><a href="/contacto.html"   class="text-white/60 hover:text-white text-sm font-figtree transition-colors">Contacto</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white/30 text-xs uppercase tracking-widest font-figtree font-semibold mb-4">Servicios</h4>
          <ul class="space-y-3">
            <li><span class="text-white/60 text-sm font-figtree">Branding &amp; Identity</span></li>
            <li><span class="text-white/60 text-sm font-figtree">Producci&oacute;n Audiovisual</span></li>
            <li><span class="text-white/60 text-sm font-figtree">Marketing Digital</span></li>
            <li><span class="text-white/60 text-sm font-figtree">IA &amp; Desarrollo Web</span></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white/30 text-xs uppercase tracking-widest font-figtree font-semibold mb-4">Contacto</h4>
          <ul class="space-y-3">
            <li><a href="mailto:info@bdbagency.com" class="text-white/60 hover:text-white text-sm font-figtree transition-colors">info@bdbagency.com</a></li>
            <li><a href="https://instagram.com/bdb.agencia" target="_blank" class="text-white/60 hover:text-white text-sm font-figtree transition-colors">Instagram</a></li>
            <li><a href="https://facebook.com/bdbagency"    target="_blank" class="text-white/60 hover:text-white text-sm font-figtree transition-colors">Facebook</a></li>
            <li><span class="text-white/60 text-sm font-figtree">Canc&uacute;n, M&eacute;xico</span></li>
          </ul>
        </div>
      </div>
      <div class="mt-16 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-white/25 text-xs font-figtree">&copy; 2025 BDB Agency. Todos los derechos reservados.</p>
        <p class="text-white/25 text-xs font-figtree">Canc&uacute;n, Quintana Roo, M&eacute;xico</p>
      </div>
    </div>
  </div>
</footer>

<script src="/effects.js"></script>
</body>
</html>
