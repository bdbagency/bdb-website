<!-- ════════════════════════════════════════════════
     HERO — Lune editorial style (white)
════════════════════════════════════════════════ -->
<section class="case-wrap" style="padding-top: 9rem;">

  <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 md:gap-12 mb-12 md:mb-16">
    <h1 class="case-title">{{ title }}<span class="period">.</span></h1>
    {% if heroSubtitle or description %}
    <p class="case-subtitle">{{ heroSubtitle if heroSubtitle else description }}</p>
    {% endif %}
  </div>

  {# Metadata row — Scope · Client · Duration · Year · (Live preview) #}
  <div class="meta-row reveal mb-10 md:mb-14">
    {% set hasItem = false %}

    {% if scope or servicios %}
      <div class="meta-item">
        <span class="meta-label">Scope</span>
        <span class="meta-value">{{ scope if scope else (servicios | first) }}</span>
      </div>
      {% set hasItem = true %}
    {% endif %}

    {% if cliente %}
      {% if hasItem %}<span class="meta-sep">/</span>{% endif %}
      <div class="meta-item">
        <span class="meta-label">Client</span>
        <span class="meta-value">{{ cliente }}</span>
      </div>
      {% set hasItem = true %}
    {% endif %}

    {% if duration %}
      {% if hasItem %}<span class="meta-sep">/</span>{% endif %}
      <div class="meta-item">
        <span class="meta-label">Duration</span>
        <span class="meta-value">{{ duration }}</span>
      </div>
      {% set hasItem = true %}
    {% endif %}

    {% if year %}
      {% if hasItem %}<span class="meta-sep">/</span>{% endif %}
      <div class="meta-item">
        <span class="meta-label">Year</span>
        <span class="meta-value">{{ year }}</span>
      </div>
    {% endif %}

  </div>

  {# Hero media — big rounded image or video #}
  <div class="case-hero-media reveal">
    {% if heroVideo %}
    <video id="project-hero-video" autoplay muted loop playsinline data-src="{{ heroVideo }}"
           {% if heroImage %}poster="{{ heroImage }}"{% endif %}></video>
    {% elif heroImage %}
    <img src="{{ heroImage }}" alt="{{ title }}" />
    {% endif %}
  </div>

</section>


<!-- ════════════════════════════════════════════════
     NARRATIVE — 3 sections (Challenge / Solution / Conclusion)
════════════════════════════════════════════════ -->

{% set totalSections = 0 %}
{% if challenge %}{% set totalSections = totalSections + 1 %}{% endif %}
{% if solution  %}{% set totalSections = totalSections + 1 %}{% endif %}
{% if result    %}{% set totalSections = totalSections + 1 %}{% endif %}
{% set sectionIdx = 0 %}

{% if challenge %}
{% set sectionIdx = sectionIdx + 1 %}
<section class="case-wrap narrative reveal">
  <div class="narrative-head">
    <span class="narrative-tag">Challenge</span>
    <span class="narrative-count">0{{ sectionIdx }} / 0{{ totalSections }}</span>
  </div>
  <h2 class="narrative-heading">{{ challenge | firstSentence }}</h2>
  {% set rest = challenge | afterFirstSentence %}
  {% if rest %}<p class="narrative-body">{{ rest }}</p>{% endif %}
</section>

{# Inline media block 1: 2-column #}
{% if gallery and gallery.length >= 2 %}
<div class="case-wrap inline-media reveal">
  <div class="row cols-2">
    <div class="frame"><img src="{{ gallery[0].src }}" alt="{{ gallery[0].alt if gallery[0].alt else title }}" loading="lazy" /></div>
    <div class="frame"><img src="{{ gallery[1].src }}" alt="{{ gallery[1].alt if gallery[1].alt else title }}" loading="lazy" /></div>
  </div>
</div>
{% endif %}
{% endif %}


{% if solution %}
{% set sectionIdx = sectionIdx + 1 %}
<section class="case-wrap narrative reveal">
  <div class="narrative-head">
    <span class="narrative-tag">Solution</span>
    <span class="narrative-count">0{{ sectionIdx }} / 0{{ totalSections }}</span>
  </div>
  <h2 class="narrative-heading">{{ solution | firstSentence }}</h2>
  {% set rest = solution | afterFirstSentence %}
  {% if rest %}<p class="narrative-body">{{ rest }}</p>{% endif %}
</section>

{# Inline media block 2: full-width #}
{% if gallery and gallery.length >= 3 %}
<div class="case-wrap inline-media reveal">
  <div class="row cols-1">
    <div class="frame wide"><img src="{{ gallery[2].src }}" alt="{{ gallery[2].alt if gallery[2].alt else title }}" loading="lazy" /></div>
  </div>
</div>
{% endif %}
{% endif %}


{% if result %}
{% set sectionIdx = sectionIdx + 1 %}
<section class="case-wrap narrative reveal">
  <div class="narrative-head">
    <span class="narrative-tag">Conclusion</span>
    <span class="narrative-count">0{{ sectionIdx }} / 0{{ totalSections }}</span>
  </div>
  <h2 class="narrative-heading">{{ result | firstSentence }}</h2>
  {% set rest = result | afterFirstSentence %}
  {% if rest %}<p class="narrative-body">{{ rest }}</p>{% endif %}
</section>

{# Inline media block 3: full-width #}
{% if gallery and gallery.length >= 4 %}
<div class="case-wrap inline-media reveal">
  <div class="row cols-1">
    <div class="frame"><img src="{{ gallery[3].src }}" alt="{{ gallery[3].alt if gallery[3].alt else title }}" loading="lazy" /></div>
  </div>
</div>
{% endif %}
{% endif %}


{# Remaining gallery items (5+) — render as 2-col bottom block #}
{% if gallery and gallery.length > 4 %}
<div class="case-wrap inline-media reveal" style="margin-top: 1rem;">
  <div class="row cols-2">
    {% for item in gallery %}
      {% if loop.index0 >= 4 %}
      <div class="frame"><img src="{{ item.src }}" alt="{{ item.alt if item.alt else title }}" loading="lazy" /></div>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% endif %}


<!-- ════════════════════════════════════════════════
