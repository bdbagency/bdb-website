<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  {# SEO #}
  <title>{{ title }} — Portafolio | BDB Agency</title>
  <meta name="description" content="{{ description if description else title }}" />
  <link rel="icon" href="/img/favicon.png" />
  <link rel="canonical" href="{{ site.url }}/proyectos/{{ page.fileSlug }}/" />

  {# Open Graph #}
  <meta property="og:type"        content="article" />
  <meta property="og:title"       content="{{ title }} — BDB Agency" />
  <meta property="og:description" content="{{ description if description else title }}" />
  <meta property="og:url"         content="{{ site.url }}/proyectos/{{ page.fileSlug }}/" />
  <meta property="og:image"       content="{{ site.url }}{{ heroImage if heroImage else site.ogImage }}" />

  {# JSON-LD #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": "{{ title | replace('"', '\\"') }}",
    "description": "{{ (description if description else title) | replace('"', '\\"') }}",
    "creator": { "@type": "Organization", "name": "BDB Agency", "url": "{{ site.url }}" },
    "url": "{{ site.url }}/proyectos/{{ page.fileSlug }}/"
  }
  </script>

  <!-- HLS.js for hero video -->
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest/dist/hls.min.js"></script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Almarai:wght@300;400;700;800&family=Figtree:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            dark:        '#0e1011',
            'dark-card': '#202527',
            'dark-bd':   '#2c2e2f',
            cream:       '#fdfbf6',
            'light-g':   '#f6f6f6',
            lime:        '#0FB4F7',
          },
          fontFamily: {
            almarai: ['Almarai', 'sans-serif'],
            figtree: ['Figtree', 'sans-serif'],
            serif:   ['Instrument Serif', 'Georgia', 'serif'],
            inter:   ['Inter', 'system-ui', 'sans-serif'],
          },
        }
      }
    }
  </script>

  <style>
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #ffffff;
      color: #0e1011;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── REVEAL ── */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.75s cubic-bezier(.25,.46,.45,.94), transform 0.75s cubic-bezier(.25,.46,.45,.94); }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── NAV (white BDB) ── */
    #navbar { background: transparent; }
    .nav-part { background: rgba(255,255,255,0.95); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); transition: all 0.5s cubic-bezier(.4,0,.2,1); }
    .nav-center { border-radius: 0 0 20px 20px; }
    .nav-left  { border-radius: 24px 0 20px 0; background: transparent; backdrop-filter: none; -webkit-backdrop-filter: none; }
    .nav-right { border-radius: 0 24px 0 20px; background: transparent; backdrop-filter: none; -webkit-backdrop-filter: none; }
    .nav-left, .nav-right { opacity: 1; max-width: 200px; overflow: hidden; transition: opacity 0.4s cubic-bezier(.4,0,.2,1), max-width 0.4s cubic-bezier(.4,0,.2,1), padding 0.4s cubic-bezier(.4,0,.2,1); }
    #navbar.nav-hide-sides .nav-left, #navbar.nav-hide-sides .nav-right { opacity: 0; max-width: 0; padding-left: 0; padding-right: 0; pointer-events: none; }
    .nav-center { transition: none; }
    #navbar .nav-link { color: rgba(14,16,17,0.6); transition: color 0.3s ease; }
    #navbar .nav-link:hover { color: #0e1011; }
    #navbar .nav-logo { color: #0e1011; }
    #navbar .nav-cta-btn { background: #0e1011; color: #fff; border-radius: 500px; transition: all 0.3s ease; }
    #navbar .nav-cta-btn:hover { background: #2a2d2f; }
    #navbar .menu-bar { background: #0e1011; }
    .white-top-bar { position: fixed; top: 0; left: 0; right: 0; height: 12px; background: #fff; z-index: 40; }
    .white-top-bar::before, .white-top-bar::after { content: ''; position: absolute; bottom: -32px; width: 32px; height: 32px; }
    .white-top-bar::before { left: 12px; background: radial-gradient(circle at 100% 100%, transparent 32px, #fff 32px); }
    .white-top-bar::after  { right: 12px; background: radial-gradient(circle at 0 100%, transparent 32px, #fff 32px); }
    #mobile-menu { transform: translateX(100%); transition: transform 0.35s cubic-bezier(.77,0,.175,1); }
    #mobile-menu.open { transform: translateX(0); }

    /* ════════════════════════════════════════
       LUNE-STYLE EDITORIAL CASE STUDY
    ════════════════════════════════════════ */

    .case-wrap {
      max-width: 1280px;
      margin: 0 auto;
      padding-left: 2rem;
      padding-right: 2rem;
    }
    @media (max-width: 768px) {
      .case-wrap { padding-left: 1.25rem; padding-right: 1.25rem; }
    }

    /* HERO TITLE — massive, tight, with period */
    .case-title {
      font-family: 'Inter', system-ui, sans-serif;
      font-weight: 600;
      letter-spacing: -0.045em;
      line-height: 0.92;
      color: #0e1011;
      font-size: clamp(4rem, 13vw, 11rem);
      margin: 0;
    }
    .case-title .period {
      color: #0e1011;
    }

    .case-subtitle {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 14px;
      line-height: 1.55;
      color: rgba(14,16,17,0.55);
      max-width: 22rem;
      font-weight: 400;
    }

    /* METADATA ROW */
    .meta-row {
      display: flex;
      align-items: center;
      gap: 1.75rem;
      flex-wrap: wrap;
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
      border-top: 1px solid rgba(14,16,17,0.08);
      border-bottom: 1px solid rgba(14,16,17,0.08);
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 13px;
    }
    .meta-row .meta-item {
      display: inline-flex;
      align-items: baseline;
      gap: 0.4rem;
    }
    .meta-row .meta-label {
      color: rgba(14,16,17,0.4);
      font-weight: 400;
    }
    .meta-row .meta-value {
      color: #0e1011;
      font-weight: 500;
    }
    .meta-row .meta-sep {
      color: rgba(14,16,17,0.18);
      padding: 0 0.25rem;
    }
    .meta-row .meta-cta {
      margin-left: auto;
    }

    /* PILL BUTTON */
    .pill-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.55rem 1.1rem;
      border-radius: 9999px;
      border: 1px solid rgba(14,16,17,0.14);
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: #0e1011;
      background: #fff;
      transition: all 0.25s ease;
      white-space: nowrap;
    }
    .pill-btn:hover {
      background: #0e1011;
      color: #fff;
      border-color: #0e1011;
    }
    .pill-btn svg { transition: transform 0.25s ease; }
    .pill-btn:hover svg { transform: translateX(2px); }

    /* HERO MEDIA */
    .case-hero-media {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 7;
      border-radius: 20px;
      overflow: hidden;
      background: #f2f2f2;
    }
    .case-hero-media img,
    .case-hero-media video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    @media (max-width: 768px) {
      .case-hero-media { aspect-ratio: 4 / 3; border-radius: 14px; }
    }

    /* NARRATIVE SECTIONS */
    .narrative {
      padding-top: 6.5rem;
      padding-bottom: 2.5rem;
    }
    .narrative-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 1.75rem;
    }
    .narrative-tag {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: #0e1011;
    }
    .narrative-tag::before { content: '/'; color: rgba(14,16,17,0.4); margin-right: 0.05em; }
    .narrative-count {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 12px;
      color: rgba(14,16,17,0.35);
      letter-spacing: 0.01em;
      font-variant-numeric: tabular-nums;
    }
    .narrative-heading {
      font-family: 'Inter', system-ui, sans-serif;
      font-weight: 600;
      letter-spacing: -0.025em;
      line-height: 1.08;
      color: #0e1011;
      font-size: clamp(1.85rem, 3.6vw, 3rem);
      max-width: 36ch;
      margin: 0 0 1.25rem 0;
    }
    .narrative-body {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 14px;
      line-height: 1.65;
      color: rgba(14,16,17,0.5);
      max-width: 42ch;
      margin: 0;
    }

    /* INLINE IMAGE BLOCKS BETWEEN SECTIONS */
    .inline-media {
      margin-top: 3rem;
    }
    .inline-media .row {
      display: grid;
      gap: 1rem;
    }
    .inline-media .row.cols-2 { grid-template-columns: 1fr 1fr; }
    .inline-media .row.cols-1 { grid-template-columns: 1fr; }
    @media (max-width: 768px) {
      .inline-media .row.cols-2 { grid-template-columns: 1fr; }
    }
    .inline-media .frame {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      border-radius: 16px;
      background: #f2f2f2;
    }
    .inline-media .frame.tall { aspect-ratio: 4 / 5; }
    .inline-media .frame.wide { aspect-ratio: 21 / 9; }
    .inline-media .frame img,
    .inline-media .frame video {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform 0.6s cubic-bezier(.25,.46,.45,.94);
    }
    .inline-media .frame:hover img,
    .inline-media .frame:hover video { transform: scale(1.025); }

    /* LATEST PROJECTS GRID */
    .latest-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 2rem;
      margin-bottom: 2.5rem;
    }
    .latest-title {
      font-family: 'Inter', system-ui, sans-serif;
      font-weight: 600;
      letter-spacing: -0.035em;
      line-height: 1;
      color: #0e1011;
      font-size: clamp(2rem, 4.5vw, 3.25rem);
      margin: 0 0 0.6rem 0;
    }
    .latest-sub {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 13px;
      color: rgba(14,16,17,0.5);
      max-width: 22rem;
    }
    .project-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }
    @media (max-width: 768px) {
      .project-grid { grid-template-columns: 1fr; }
      .latest-head { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
    }
    .project-card {
      position: relative;
      display: block;
      border-radius: 16px;
      overflow: hidden;
      aspect-ratio: 4 / 3;
      background: #f2f2f2;
      isolation: isolate;
    }
    .project-card img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform 0.7s cubic-bezier(.25,.46,.45,.94);
    }
    .project-card:hover img { transform: scale(1.04); }
    .project-card .card-overlay {
      position: absolute;
      left: 1rem; right: 1rem; bottom: 1rem;
      background: rgba(14,16,17,0.92);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-radius: 12px;
      padding: 0.85rem 1.1rem;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
      color: #fff;
    }
    .project-card .card-title {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 14px;
      font-weight: 500;
      line-height: 1.2;
      margin: 0 0 0.15rem 0;
    }
    .project-card .card-meta {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 12px;
      color: rgba(255,255,255,0.55);
      margin: 0;
    }
    .project-card .card-year {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 12px;
      color: rgba(255,255,255,0.55);
      font-variant-numeric: tabular-nums;
    }
    .project-card .card-tag {
      position: absolute;
      top: 1rem; left: 1rem;
      background: #ef4444;
      color: #fff;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 11px;
      font-weight: 500;
      padding: 0.3rem 0.7rem;
      border-radius: 9999px;
    }

    /* ── TESTIMONIAL ── */
    .tquote {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 15px;
      font-weight: 400;
      line-height: 1.8;
      color: rgba(14,16,17,0.65);
      margin: 1.25rem 0 0 0;
    }
    .tquote:first-child { margin-top: 0; }
    @media (max-width: 768px) {
      .tquote-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
    }

    /* LIGHTBOX */
    #lightbox {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.94); z-index: 200;
      align-items: center; justify-content: center;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    #lightbox.open { display: flex; }
    #lightbox img {
      max-width: 90vw; max-height: 90vh;
      object-fit: contain;
      border-radius: 8px;
      box-shadow: 0 40px 120px rgba(0,0,0,0.7);
    }
    #lightbox-close {
      position: absolute; top: 24px; right: 28px;
      width: 44px; height: 44px; border-radius: 50%;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.15);
      color: #fff; font-size: 20px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: background 0.2s ease;
    }
    #lightbox-close:hover { background: rgba(255,255,255,0.2); }
  </style>
</head>
<body>

<!-- NAV -->
