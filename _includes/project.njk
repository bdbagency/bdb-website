════════════════════════════════════════════════ -->
{% if testimonialText %}
<section class="case-wrap reveal" style="padding-top: 6rem; padding-bottom: 2rem;">
  <div style="border-top: 1px solid rgba(14,16,17,0.08); padding-top: 3.5rem; display:grid; grid-template-columns: 1fr 1.6fr; gap: 4rem; align-items: start;">

    {# LEFT — author #}
    <div>
      <span style="font-family:'Inter',system-ui,sans-serif;font-size:13px;font-weight:500;color:#0e1011;display:block;margin-bottom:2rem;">
        <span style="color:rgba(14,16,17,0.4);">/</span>Testimonio
      </span>
      <div style="display:flex;align-items:center;gap:0.85rem;">
        <div style="width:2.5rem;height:2.5rem;border-radius:50%;background:#0e1011;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          {% if testimonialAvatar %}
          <img src="{{ testimonialAvatar }}" alt="{{ testimonialAuthor }}"
               style="width:100%;height:100%;border-radius:50%;object-fit:cover;" />
          {% else %}
          <span style="font-family:'Instrument Serif',Georgia,serif;font-style:italic;color:#fff;font-size:0.9rem;">{{ testimonialAuthor[0] if testimonialAuthor else '?' }}</span>
          {% endif %}
        </div>
        <div>
          <p style="font-family:'Inter',system-ui,sans-serif;font-size:13px;font-weight:600;color:#0e1011;margin:0 0 0.2rem 0;">{{ testimonialAuthor }}</p>
          {% if testimonialRole %}
          <p style="font-family:'Inter',system-ui,sans-serif;font-size:12px;color:rgba(14,16,17,0.45);margin:0;line-height:1.45;">{{ testimonialRole }}</p>
          {% endif %}
        </div>
      </div>
    </div>

    {# RIGHT — quote text #}
    <blockquote style="margin:0;padding:0;">
      <p class="tquote">&ldquo;{{ testimonialText | replace('\n\n', '&rdquo;</p><p class="tquote">&ldquo;') | safe }}&rdquo;</p>
    </blockquote>

  </div>
</section>
{% endif %}

